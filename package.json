{
  "name": "ulysse-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "build": "next build",
    "start": "next start",
    "icons": "node scripts/gen-favicon.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "next": "14.2.5",
    "nodemailer": "^9.0.1",
    "react": "^18",
    "react-dom": "^18",
    "three": "^0.164.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.164.0",
    "sharp": "^0.35.2",
    "to-ico": "^1.1.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
