# SMTP pour le formulaire de contact (Gmail ou autre)
# En local : copier en .env.local et remplir les valeurs
# En production : mêmes variables que SITE_VITRINE_FREELANCE_ULYSSE

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=gomingjobertulysse@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application
# Adresse affichée à l'envoi (email seul ou "Nom <email>")
DEFAULT_FROM_EMAIL=Ulysse Goming Jobert <gomingjobertulysse@gmail.com>

# Optionnel : destinataire différent de l'expéditeur
# CONTACT_TO_EMAIL=autre-email@gmail.com

# URL publique (SEO, sitemap, Open Graph) — ex. https://ulysse-goming-jobert.vercel.app
# En Docker/Dokploy : passer en ARG de build (NEXT_PUBLIC_SITE_URL) ou variable au build
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr

# ── Dokploy / Docker ──
# Port exposé par le conteneur (défaut 3000)
# PORT=3000
#
# Variables runtime (formulaire contact) :
# EMAIL_HOST, EMAIL_PORT, EMAIL_HOST_USER, EMAIL_HOST_PASSWORD, DEFAULT_FROM_EMAIL
# Optionnel : CONTACT_TO_EMAIL
