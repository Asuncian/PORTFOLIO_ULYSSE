# Rate limiting — stack Hetzner CX23 + Dokploy
#
# Dokploy gère déjà le reverse proxy HTTPS (Traefik) vers votre conteneur Docker.
# Le rate limiting applicatif (IP + email) est intégré dans /api/contact.
#
# Complément optionnel côté serveur :
# - Pare-feu Hetzner Cloud (limiter les ports exposés : 80, 443, 22)
# - Fail2ban sur SSH
# - Middleware Traefik (si vous étendez la config Dokploy)
#
# Exemple Nginx si vous ajoutez un proxy devant Dokploy (non requis par défaut) :

limit_req_zone $binary_remote_addr zone=contact_api:10m rate=10r/m;

server {
    listen 443 ssl http2;
    server_name ulysse-goming-jobert.dev;

    location /api/contact {
        limit_req zone=contact_api burst=3 nodelay;
        limit_req_status 429;
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# DNS : enregistrement A chez Infomaniak → IP publique du VPS Hetzner CX23
